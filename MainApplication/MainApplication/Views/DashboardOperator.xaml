<Window x:Class="MainApplication.Views.DashboardOperator"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Operator Terminal" Height="800" Width="1250" Background="#F0F2F5" WindowStartupLocation="CenterScreen">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="60"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Border Background="#1A3D73">
			<DockPanel Margin="20,0">
				<TextBlock Text="OPERATOR WORKSTATION" Foreground="White" VerticalAlignment="Center" FontWeight="Bold"/>
				<Button Content="LOGOUT" Click="btnLogout_Click" DockPanel.Dock="Right" Width="80" Height="30" Background="#D9534F" Foreground="White"/>
			</DockPanel>
		</Border>

		<Grid Grid.Row="1" Margin="20">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="350"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<Border Background="White" CornerRadius="10" Padding="15">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>
					<TextBlock Text="LOCAL STOCK" FontWeight="Bold" Margin="0,0,0,10"/>
					<ListBox x:Name="InventoryList" Grid.Row="1" BorderThickness="0">
						<ListBox.ItemTemplate>
							<DataTemplate>
								<StackPanel Margin="0,10">
									<CheckBox Content="{Binding MaterialName}" IsChecked="{Binding IsSelected}" FontWeight="Bold"/>
									<ProgressBar Value="{Binding QuantityPercentage}" Height="8" Margin="0,5" Foreground="#2C5AA0"/>
								</StackPanel>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
					<Button Grid.Row="2" Content="SEND REFILL REQUEST" Click="btnRequestStock_Click" Height="45" Background="#2C5AA0" Foreground="White" FontWeight="Bold" Margin="0,10,0,0"/>
				</Grid>
			</Border>

			<ScrollViewer Grid.Column="1" Margin="20,0,0,0">
				<ItemsControl x:Name="LinesControl">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Width="280" Height="200" Background="White" Margin="10" CornerRadius="12" BorderBrush="#2C5AA0" BorderThickness="1" MouseDown="LineCard_MouseDown" Cursor="Hand">
								<StackPanel VerticalAlignment="Center">
									<TextBlock Text="{Binding LineName}" FontWeight="Bold" FontSize="22" HorizontalAlignment="Center" Foreground="#1A3D73"/>
									<TextBlock Text="{Binding StatusText}" Foreground="Green" HorizontalAlignment="Center" Margin="0,10" FontSize="16"/>
									<TextBlock Text="{Binding CurrentProduct}" Foreground="Gray" HorizontalAlignment="Center" FontStyle="Italic"/>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>
		</Grid>
	</Grid>
</Window>