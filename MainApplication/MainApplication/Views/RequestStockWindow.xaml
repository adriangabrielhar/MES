<Window x:Class="MainApplication.Views.RequestStockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Material Request" Height="500" Width="400"
        WindowStartupLocation="CenterOwner" Background="#F0F0F0" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="REQUEST MATERIALS" FontSize="18" FontWeight="Bold" Foreground="#2C5AA0" Margin="0,0,0,15"/>

        <DockPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <TextBox x:Name="txtSearch" Height="25" TextChanged="txtSearch_TextChanged"/>
        </DockPanel>

        <ListBox x:Name="lbMaterials" Grid.Row="2" Background="White" BorderBrush="#D0D4D9">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5" Width="320">
                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding MaterialName}" Width="150" Margin="5,0"/>
                                <TextBlock Text="Qty:" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="10"/>
                                <TextBox Text="{Binding RequestedQuantity}" Width="50" Height="20"/>
                            </StackPanel>
                        </CheckBox>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <UniformGrid Grid.Row="3" Columns="2" Margin="0,20,0,0">
            <Button Content="CANCEL" Click="Cancel_Click" Margin="5" Height="35" Background="#A0A0A0" Foreground="White"/>
            <Button Content="SEND REQUEST" Click="Send_Click" Margin="5" Height="35" Background="#2C5AA0" Foreground="White" FontWeight="Bold"/>
        </UniformGrid>
    </Grid>
</Window>