<Window x:Class="MainApplication.Views.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System User Management" Height="400" Width="400" 
        WindowStartupLocation="CenterOwner" Background="#F0F2F5">
    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="CREATE NEW USER" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="#1A3D73"/>

            <TextBlock Text="Username:" Margin="0,5"/>
            <TextBox x:Name="txtNewUsername" Height="30" VerticalContentAlignment="Center"/>

            <TextBlock Text="Password:" Margin="0,10,0,5"/>
            <PasswordBox x:Name="txtNewPassword" Height="30" VerticalContentAlignment="Center"/>

            <TextBlock Text="Assign Role:" Margin="0,10,0,5"/>
            <ComboBox x:Name="cmbRole" Height="30" SelectedIndex="0">
                <ComboBoxItem Content="Operator"/>
                <ComboBoxItem Content="Admin"/>
            </ComboBox>

            <!-- Butonul de salvare care va declanșa logica de Backend -->
            <Button Content="REGISTER USER" Click="btnSaveUser_Click" Margin="0,30,0,0" 
                    Height="40" Background="#28A745" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>