<Window x:Class="MainApplication.Views.AdminApprovalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pending Requests Approval" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" Background="#F0F0F0">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="PENDING OPERATOR REQUESTS" FontSize="18" FontWeight="Bold" Foreground="#2C5AA0" Margin="0,0,0,15"/>

        <ListBox x:Name="lbRequests" Grid.Row="1" Background="White" HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Details}" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Time}" FontSize="10" Foreground="Gray"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="✔" Background="Green" Foreground="White" Width="35" Margin="5,0" 
                                        Click="Approve_Click" Tag="{Binding Id}"/>
                                <Button Content="✖" Background="Red" Foreground="White" Width="35" 
                                        Click="Reject_Click" Tag="{Binding Id}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Grid.Row="2" Content="CLOSE" Click="Close_Click" Margin="0,15,0,0" Height="30"/>
    </Grid>
</Window>