<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MainApplication.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Console" Height="800" Width="1200" Background="#F0F2F5" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#1A3D73">
            <DockPanel Margin="20,0">
                <TextBlock Text="XACT-FIL ADMIN" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <!-- BUTON NOU: GESTIONARE USERI -->
                    <Button Content="MANAGE USERS" Click="btnManageUsers_Click" Width="120" Height="30" Margin="0,0,10,0" Background="#2C5AA0" Foreground="White" FontWeight="Bold"/>
                    <Button Content="LOGOUT" Click="btnLogout_Click" Width="80" Height="30" Background="#D9534F" Foreground="White"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <!-- OVERVIEW: Neschimbat -->
            <TabItem Header="OVERVIEW">
                <Border Padding="20">
                    <UniformGrid Columns="3">
                        <Border Background="White" Margin="10" CornerRadius="8">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="TOTAL LINES" HorizontalAlignment="Center" Foreground="Gray"/>
                                <TextBlock x:Name="txtTotalLines" Text="0" FontSize="35" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#2C5AA0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="White" Margin="10" CornerRadius="8">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="RUNNING" HorizontalAlignment="Center" Foreground="Gray"/>
                                <TextBlock x:Name="txtRunningLines" Text="0" FontSize="35" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Green"/>
                            </StackPanel>
                        </Border>
                        <Border Background="White" Margin="10" CornerRadius="8">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="AVAILABLE" HorizontalAlignment="Center" Foreground="Gray"/>
                                <TextBlock x:Name="txtAvailableLines" Text="0" FontSize="35" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Orange"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Border>
            </TabItem>

            <!-- MONITORING: Neschimbat -->
            <TabItem Header="MONITORING">
                <Border Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Button Content="+ ADD LINE" Click="btnAddLine_Click" HorizontalAlignment="Right" Margin="0,0,0,15" Background="Green" Foreground="White" Padding="10,5"/>
                        <ScrollViewer Grid.Row="1">
                            <ItemsControl x:Name="LinesControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="280" Height="200" Background="White" Margin="10" CornerRadius="10" MouseDown="LineCard_MouseDown" Cursor="Hand" BorderBrush="#DDD" BorderThickness="1">
                                            <Border Padding="15">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding LineName}" FontWeight="Bold" FontSize="16"/>
                                                    <TextBlock Text="{Binding StatusText}" Foreground="Gray" FontSize="12"/>
                                                    <Border Background="#E3F2FD" CornerRadius="4" Padding="8" Margin="0,8,0,0">
                                                        <TextBlock Text="{Binding LineType}" Foreground="#1A3D73" FontSize="11" FontWeight="SemiBold" TextAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                        <TextBlock Text="Produs: " Foreground="Gray" FontSize="12"/>
                                                        <TextBlock Text="{Binding CurrentProduct}" FontWeight="SemiBold" FontSize="12"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </TabItem>

            <!-- PRODUCTION: Corectat Layout (fără coloană goală) -->
            <TabItem Header="PRODUCTION">
                <Border Padding="20">
                    <Border Background="White" CornerRadius="10" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="PRODUCTION LOGISTICS" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                                <Button Content="OPEN APPROVAL TERMINAL" Click="btnOpenApproval_Click" Height="45" Background="Orange" Foreground="White" FontWeight="Bold"/>
                            </StackPanel>

                            <ListBox x:Name="lstRequests" Grid.Row="1" Margin="0,15,0,0" DisplayMemberPath="Details" BorderThickness="0" Background="#F9F9F9"/>
                        </Grid>
                    </Border>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
