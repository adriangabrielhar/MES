<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MainApplication.Views.AddLineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Production Line" Height="333" Width="465" 
        WindowStartupLocation="CenterOwner" Background="#F0F2F5" ResizeMode="NoResize">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="CREATE NEW PRODUCTION LINE" FontSize="16" FontWeight="Bold" Margin="0,0,0,25" Foreground="#1A3D73"/>

            <TextBlock Text="Line Name:" Margin="0,0,0,8" FontWeight="SemiBold"/>
            <TextBox x:Name="txtLineName" Height="35" Padding="10" VerticalContentAlignment="Center" Background="White" BorderBrush="#DDD"/>

            <TextBlock Text="Line Type:" Margin="0,20,0,8" FontWeight="SemiBold"/>
            <ComboBox x:Name="cmbLineType" Height="35" VerticalContentAlignment="Center" Background="White" BorderBrush="#DDD">
                <ComboBoxItem Content="Sub-Assembly" IsSelected="True"/>
                <ComboBoxItem Content="Final Product"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" Margin="0,30,0,0" HorizontalAlignment="Right">
                <Button Content="CANCEL" Click="btnCancel_Click" Width="100" Height="40" Background="#DC3545" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
                <Button Content="CREATE" Click="btnCreate_Click" Width="100" Height="40" Background="#28A745" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>