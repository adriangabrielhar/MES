<Window x:Class="MainApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XACT-FIL MES - Login" Height="450" Width="800"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <DropShadowEffect x:Key="LoginShadow" BlurRadius="20" Color="#ADADAD" Opacity="0.5" ShadowDepth="5"/>
    </Window.Resources>

    <Border CornerRadius="15" Background="White" Margin="50" Effect="{StaticResource LoginShadow}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1A3D73" CornerRadius="15,0,0,15">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="XACT-FIL" Foreground="White" FontSize="42" FontWeight="Black" HorizontalAlignment="Center"/>
                    <TextBlock Text="MES ENTERPRISE" Foreground="#A0C4FF" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <Rectangle Width="50" Height="2" Fill="Yellow" Margin="0,20,0,0"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="30">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="SISTEM AUTENTIFICARE" FontSize="18" FontWeight="Bold" Foreground="#333" Margin="0,0,0,30" HorizontalAlignment="Center"/>

                    <TextBlock Text="Utilizator" Foreground="Gray" Margin="0,0,0,5"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,15">
                        <TextBox x:Name="txtUsername" Height="35" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0" FontSize="14"/>
                    </Border>

                    <TextBlock Text="Parolă" Foreground="Gray" Margin="0,0,0,5"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,25">
                        <PasswordBox x:Name="txtPassword" Height="35" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"/>
                    </Border>

                    <Button Content="AUTENTIFICARE" 
                            Click="LoginButton_Click" 
							IsDefault="True"
                            Height="45" 
                            Background="#1A3D73" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Închide Aplicația" Click="btnExit_Click" Background="Transparent" Foreground="Gray" BorderThickness="0" Margin="0,15,0,0" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>