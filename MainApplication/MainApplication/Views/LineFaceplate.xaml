<Window x:Class="MainApplication.Views.LineFaceplate"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Line Faceplate - Control Manual" Height="800" Width="1100"
        WindowStartupLocation="CenterOwner" Background="#F0F2F5" ResizeMode="NoResize">
	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<!-- Header -->
			<RowDefinition Height="*"/>
			<!-- Body -->
			<RowDefinition Height="Auto"/>
			<!-- Footer -->
		</Grid.RowDefinitions>

		<!-- HEADER DINAMIC -->
		<Border Grid.Row="0" x:Name="brdHeader" Background="#1A3D73" Padding="15" Margin="0,0,0,15" CornerRadius="8">
			<DockPanel>
				<StackPanel>
					<TextBlock x:Name="txtLineName" Text="LINE 01" Foreground="White" FontSize="26" FontWeight="Bold"/>
					<TextBlock x:Name="txtProduct" Text="Product: În așteptare..." Foreground="#A0C4FF" FontSize="14"/>
				</StackPanel>
				<Border x:Name="brdStatusBadge" HorizontalAlignment="Right" VerticalAlignment="Center" CornerRadius="15" Padding="20,8" Background="#28A745">
					<TextBlock x:Name="lblStatus" Text="ONLINE" Foreground="White" FontWeight="Bold" FontSize="14"/>
				</Border>
			</DockPanel>
		</Border>

		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="300"/>
				<!-- C1: Gestiune Stoc -->
				<ColumnDefinition Width="*"/>
				<!-- C2: Configurare & Mentenanță -->
				<ColumnDefinition Width="320"/>
				<!-- C3: Status Producție -->
			</Grid.ColumnDefinitions>

			<!-- COLOANA 1: GESTIUNE STOC -->
			<GroupBox Header="Gestiune Stoc Linie" Margin="0,0,10,0" Padding="5">
				<ListBox x:Name="lstRestockItems" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="8,5">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>
									<TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
									<Button Grid.Column="1" Content="REQUEST" Width="75" Height="25"
                                            Background="#1A3D73" Foreground="White" FontWeight="Bold" FontSize="10"
                                            Click="btnRequestRestock_Click" Tag="{Binding Name}"/>
								</Grid>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
			</GroupBox>

			<!-- COLOANA 2: CONFIGURARE ȘI MENTENANȚĂ -->
			<Grid Grid.Column="1" Margin="5,0">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<GroupBox Grid.Row="0" Header="Configurare Lot" Margin="0,0,0,10" Padding="10">
					<StackPanel>
						<TextBlock Text="Selectați Produsul:" Margin="0,0,0,5" Foreground="#555"/>
						<ComboBox x:Name="cmbProductSelection" Height="35" VerticalContentAlignment="Center"
                                  SelectionChanged="cmbProductSelection_SelectionChanged"/>
					</StackPanel>
				</GroupBox>

				<GroupBox Grid.Row="1" Header="Verificare Materiale (BOM)" Padding="10">
					<ItemsControl x:Name="icBOMStatus">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Grid Margin="0,8">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>
									<TextBlock Text="{Binding MaterialName}" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>
									<Rectangle Grid.Column="1" Width="100" Height="18" RadiusX="9" RadiusY="9" Fill="{Binding StatusColor}"/>
								</Grid>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</GroupBox>

				<GroupBox Grid.Row="2" Header="Mentenanță" Margin="0,10,0,0" Padding="10">
					<DockPanel>
						<StackPanel>
							<TextBlock Text="Ultima Revizie:" FontSize="11" Foreground="Gray"/>
							<TextBlock x:Name="txtLastService" Text="2026-02-10" FontWeight="Bold" FontSize="14" Foreground="#1A3D73"/>
						</StackPanel>
						<Button Content="SOLICITĂ SERVICE" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="#FF8C00" Foreground="White" FontWeight="Bold" Padding="15,8"
                                Click="btnMaintenance_Click"/>
					</DockPanel>
				</GroupBox>
			</Grid>

			<!-- COLOANA 3: MONITORIZARE BATCH -->
			<GroupBox Header="Monitorizare Batch" Grid.Column="2">
				<StackPanel VerticalAlignment="Center">
					<TextBlock Text="TIMP ESTIMAT FINALIZARE" HorizontalAlignment="Center" Foreground="#555" FontWeight="Bold"/>
					<Grid Margin="0,25">
						<Ellipse Stroke="#E0E0E0" StrokeThickness="10" Width="170" Height="170"/>
						<StackPanel VerticalAlignment="Center">
							<TextBlock x:Name="txtTimeRemaining" Text="00:00:00" FontSize="34" FontWeight="Black" Foreground="#1A3D73" HorizontalAlignment="Center"/>
							<TextBlock Text="HH:MM:SS" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
						</StackPanel>
					</Grid>
					<ProgressBar x:Name="pbBatchProgress" Height="22" Margin="20,0" Foreground="#28A745" Background="#DDD"/>
					<TextBlock Text="Progres Producție" HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="11" Foreground="Gray"/>
				</StackPanel>
			</GroupBox>
		</Grid>

		<!-- FOOTER CONTROLS -->
		<UniformGrid Grid.Row="2" Columns="3" Height="85" Margin="0,15,0,0">
			<Button Content="START" Background="#28A745" Foreground="White" FontWeight="Bold" FontSize="22" Margin="5" Click="btnStart_Click"/>
			<Button Content="STOP" Background="#FFC107" Foreground="#333" FontWeight="Bold" FontSize="22" Margin="5" Click="btnStop_Click"/>
			<Button Content="E-STOP" Background="#DC3545" Foreground="White" FontWeight="Bold" FontSize="22" Margin="5" Click="btnEStop_Click"/>
		</UniformGrid>
	</Grid>
</Window>